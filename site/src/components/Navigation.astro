---
const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

const links = [
  { href: `${base}`, label: 'Home' },
  { href: `${base}principles/`, label: 'Core Principles' },
  { href: `${base}manifesto/`, label: 'Manifesto' },
  { href: `${base}constitution/`, label: 'Constitution' },
  { href: `${base}charter/`, label: 'Cooperative Charter' },
];
---

<nav class="nav">
  <div class="nav-inner">
    <a href={base} class="nav-title">FSA</a>
    <button class="nav-toggle" aria-label="Toggle navigation" aria-expanded="false">
      <span class="nav-toggle-bar"></span>
      <span class="nav-toggle-bar"></span>
      <span class="nav-toggle-bar"></span>
    </button>
    <ul class="nav-links">
      {links.map(link => (
        <li>
          <a
            href={link.href}
            class:list={['nav-link', { active: currentPath === link.href }]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
    <button class="theme-toggle" aria-label="Toggle theme" title="Toggle light/dark theme">
      <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="12" cy="12" r="5"/>
        <line x1="12" y1="1" x2="12" y2="3"/>
        <line x1="12" y1="21" x2="12" y2="23"/>
        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
        <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
        <line x1="1" y1="12" x2="3" y2="12"/>
        <line x1="21" y1="12" x2="23" y2="12"/>
        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
        <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
      </svg>
      <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
      </svg>
    </button>
  </div>
</nav>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: var(--bg);
    border-bottom: 1px solid var(--border);
  }

  .nav-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 0.75rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .nav-title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: 0.15em;
    color: var(--accent);
    text-decoration: none;
    border-bottom: none;
    flex-shrink: 0;
  }

  .nav-title:hover {
    border-bottom: none;
  }

  .nav-links {
    display: flex;
    list-style: none;
    gap: 0.25rem;
    margin: 0;
    padding: 0;
    flex-wrap: wrap;
  }

  .nav-link {
    font-size: 0.8rem;
    color: var(--text-muted);
    text-decoration: none;
    padding: 0.25rem 0.5rem;
    border-radius: 3px;
    border-bottom: none;
    transition: color 0.2s ease, background-color 0.2s ease;
    white-space: nowrap;
  }

  .nav-link:hover {
    color: var(--text);
    background-color: var(--bg-surface);
    border-bottom: none;
  }

  .nav-link.active {
    color: var(--accent);
    background-color: var(--bg-elevated);
    border-bottom: none;
  }

  .nav-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    flex-direction: column;
    gap: 4px;
  }

  .nav-toggle-bar {
    display: block;
    width: 20px;
    height: 2px;
    background-color: var(--text-muted);
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  .theme-toggle {
    margin-left: auto;
    background: none;
    border: 1px solid var(--border);
    border-radius: 3px;
    cursor: pointer;
    padding: 0.35rem;
    color: var(--text-muted);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: color 0.2s ease, border-color 0.2s ease;
  }

  .theme-toggle:hover {
    color: var(--text);
    border-color: var(--border-light);
  }

  .icon-moon {
    display: block;
  }

  .icon-sun {
    display: none;
  }

  :global([data-theme="light"]) .icon-moon {
    display: none;
  }

  :global([data-theme="light"]) .icon-sun {
    display: block;
  }

  @media (max-width: 768px) {
    .nav-toggle {
      display: flex;
    }

    .nav-links {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background-color: var(--bg);
      border-bottom: 1px solid var(--border);
      flex-direction: column;
      padding: 0.5rem 1.5rem 1rem;
      gap: 0;
    }

    .nav-links.open {
      display: flex;
    }

    .nav-link {
      display: block;
      padding: 0.5rem;
    }
  }
</style>

<script>
  // Theme toggle
  const themeToggle = document.querySelector('.theme-toggle');
  const html = document.documentElement;

  const savedTheme = localStorage.getItem('theme');
  if (savedTheme) {
    html.setAttribute('data-theme', savedTheme);
  }

  themeToggle?.addEventListener('click', () => {
    const current = html.getAttribute('data-theme');
    const next = current === 'light' ? 'dark' : 'light';
    html.setAttribute('data-theme', next);
    localStorage.setItem('theme', next);
  });

  // Mobile nav toggle
  const navToggle = document.querySelector('.nav-toggle');
  const navLinks = document.querySelector('.nav-links');

  navToggle?.addEventListener('click', () => {
    const expanded = navToggle.getAttribute('aria-expanded') === 'true';
    navToggle.setAttribute('aria-expanded', String(!expanded));
    navLinks?.classList.toggle('open');
  });
</script>
