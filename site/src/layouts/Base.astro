---
import Navigation from '../components/Navigation.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'A political philosophy built on one principle: no cruelty, no exceptions.' } = Astro.props;
const fullTitle = title === 'Home'
  ? 'Fractal Secular Acruelism'
  : `${title} — Fractal Secular Acruelism`;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{fullTitle}</title>
  <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
  <script is:inline>
    // Prevent flash of wrong theme
    (function() {
      const saved = localStorage.getItem('theme');
      if (saved) document.documentElement.setAttribute('data-theme', saved);
    })();
  </script>
</head>
<body>
  <Navigation />
  <main class="main">
    <slot />
  </main>
  <footer class="footer">
    <div class="footer-rule"></div>
    <div class="footer-inner">
      <p class="footer-title">Fractal Secular Acruelism</p>
      <p class="footer-motto">No cruelty. No exceptions.</p>
      <p class="footer-link"><a href="https://github.com/nidx/fractal-secular-acruelism">Source on GitHub</a></p>
    </div>
  </footer>
</body>
</html>

<style>
  .main {
    max-width: 48rem;
    margin: 0 auto;
    padding: var(--space-3xl) 1.5rem var(--space-2xl);
    min-height: calc(100vh - 220px);
  }

  .footer {
    margin-top: var(--space-3xl);
  }

  .footer-rule {
    max-width: 48rem;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 1px;
    position: relative;
  }

  .footer-rule::after {
    content: '';
    display: block;
    height: 1px;
    background: linear-gradient(
      to right,
      transparent,
      var(--rule) 15%,
      var(--rule) 85%,
      transparent
    );
  }

  .footer-inner {
    max-width: 48rem;
    margin: 0 auto;
    padding: var(--space-xl) 1.5rem var(--space-2xl);
    text-align: center;
  }

  .footer-title {
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-dim);
    margin: 0 auto;
    max-width: 100%;
  }

  .footer-motto {
    font-family: var(--font-body);
    font-style: italic;
    font-size: 0.85rem;
    color: var(--text-dim);
    margin: var(--space-2xs) auto 0;
    max-width: 100%;
    opacity: 0.8;
  }

  .footer-link {
    margin-top: var(--space-md);
    max-width: 100%;
  }

  .footer-link a {
    font-size: 0.8rem;
    color: var(--text-dim);
    letter-spacing: 0.04em;
    border-bottom: 1px solid var(--border);
    transition: color var(--transition-fast), border-color var(--transition-fast);
  }

  .footer-link a:hover {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }

  @media (max-width: 768px) {
    .main {
      padding: var(--space-2xl) 1.25rem var(--space-xl);
    }
  }
</style>
